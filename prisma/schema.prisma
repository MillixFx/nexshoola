// NexSchoola - Multi-tenant School Management SaaS
// Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// MULTI-TENANCY
// ─────────────────────────────────────────────

model School {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique // subdomain: slug.nexschoola.com
  logo        String?
  address     String?
  phone       String?
  email       String?
  country     String   @default("GH")
  currency    String   @default("GHS")
  timezone    String   @default("Africa/Accra")
  language    String   @default("en")
  headmaster  String?
  startYear   Int?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Subscription
  plan        Plan     @default(FREE)
  planExpiry  DateTime?
  paystackRef String?

  // Paystack subaccount — for direct school payouts
  paystackSubaccountCode String?
  paystackBankCode       String?
  paystackAccountNumber  String?
  paystackAccountName    String?
  paystackBusinessName   String?

  // Platform billing
  subscriptionPaidAt DateTime?
  subscriptionNotes  String?

  // Relations
  users           User[]
  classes         Class[]
  subjects        Subject[]
  students        Student[]
  teachers        Teacher[]
  parents         Parent[]
  employees       Employee[]
  attendance      DailyAttendance[]
  exams           Exam[]
  transactions    Transaction[]
  accountTitles   AccountTitle[]
  fees            FeeItem[]
  books           Book[]
  dormitories     Dormitory[]
  transport       Transport[]
  inventoryItems  InventoryItem[]
  notices         Notice[]
  messages        Message[]
  events          CalendarEvent[]
  leaveApps       LeaveApplication[]
  suggestions     Suggestion[]
  weekDays        WeekDay[]
  salaries        SalaryConfig[]
  payslips        StaffPayslip[]
  configuration   Configuration?
  conversations   Conversation[]
  permissions     UserPermission[]

  @@map("schools")
}

enum Plan {
  FREE
  BASIC
  PRO
  ENTERPRISE
}

// ─────────────────────────────────────────────
// AUTH & USERS
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  schoolId      String
  name          String
  email         String
  password      String
  role          Role      @default(STUDENT)
  avatar        String?
  phone         String?
  isActive      Boolean   @default(true)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  school        School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student        Student?
  teacher        Teacher?
  parent         Parent?
  employee       Employee?
  libraryMember  LibraryMember?
  sentMessages     Message[]  @relation("SentMessages")
  receivedMessages MessageRecipient[]
  suggestions      Suggestion[]
  leaveApps        LeaveApplication[]
  sessions         Session[]
  events           CalendarEvent[]
  chatParticipants    ConversationParticipant[]
  chatMessages        ChatMessage[] @relation("SentChatMessages")
  createdChats        Conversation[] @relation("CreatedConversations")
  substitutesAssigned ClassSubstitute[] @relation("SubstituteAssignedBy")
  permissions         UserPermission[] @relation("GrantedPermissions")

  @@unique([schoolId, email])
  @@map("users")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  HEADMASTER
  TEACHER
  STUDENT
  PARENT
  ACCOUNTANT
  LIBRARIAN
  HOSTEL_MANAGER
  HR
  DRIVER
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  expires      DateTime
  sessionToken String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("sessions")
}

// ─────────────────────────────────────────────
// ACADEMIC STRUCTURE
// ─────────────────────────────────────────────

model Class {
  id             String   @id @default(cuid())
  schoolId       String
  name           String
  section        String?
  code           String?
  capacity       Int?
  classTeacherId String?  // the class master
  createdAt      DateTime @default(now())

  school         School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classTeacher   Teacher?      @relation("ClassTeacher", fields: [classTeacherId], references: [id])
  students       Student[]
  subjects       ClassSubject[]
  routines       ClassRoutine[]
  attendance     DailyAttendance[]
  examRoutines   ExamRoutine[]
  fees           FeeItem[]
  promotions     Promotion[]
  substitutes    ClassSubstitute[]

  @@unique([schoolId, name, section])
  @@map("classes")
}

model Subject {
  id          String   @id @default(cuid())
  schoolId    String
  title       String
  code        String?
  isOptional  Boolean  @default(false)
  group       SubjectGroup?
  bookTitle   String?
  bookWriter  String?
  bookEdition String?

  school        School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classSubjects ClassSubject[]
  routineSlots  ClassRoutine[]
  examRoutines  ExamRoutine[]
  marks         SubjectMark[]

  @@map("subjects")
}

enum SubjectGroup {
  SCIENCE
  BUSINESS
  ARTS
  GENERAL
}

model ClassSubject {
  id        String  @id @default(cuid())
  classId   String
  subjectId String
  teacherId String?

  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([classId, subjectId])
  @@map("class_subjects")
}

model ClassRoutine {
  id        String  @id @default(cuid())
  classId   String
  subjectId String
  teacherId String?
  day       DayOfWeek
  startTime String
  endTime   String
  room      String?

  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@map("class_routines")
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

// Class master substitution — who covers attendance when the class master is away
model ClassSubstitute {
  id           String    @id @default(cuid())
  schoolId     String
  classId      String
  substituteId String    // Teacher covering the class
  assignedById String    // User who assigned (class master or admin)
  startDate    DateTime  @db.Date
  endDate      DateTime? @db.Date   // null = open-ended (until further notice)
  note         String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())

  class       Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  substitute  Teacher @relation("SubstituteTeacher", fields: [substituteId], references: [id])
  assignedBy  User    @relation("SubstituteAssignedBy", fields: [assignedById], references: [id])

  @@map("class_substitutes")
}

// ─────────────────────────────────────────────
// PEOPLE
// ─────────────────────────────────────────────

model Student {
  id          String   @id @default(cuid())
  schoolId    String
  userId      String   @unique
  classId     String?
  rollNumber  String?
  studentId   String?
  dateOfBirth DateTime?
  gender      Gender?
  address     String?
  bloodGroup  String?
  religion    String?
  nationality String?
  photo       String?
  admissionDate DateTime @default(now())
  isActive    Boolean  @default(true)

  school    School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  class     Class?    @relation(fields: [classId], references: [id])
  parents   StudentParent[]
  attendance DailyAttendance[]
  examAttendance ExamAttendance[]
  marks     SubjectMark[]
  fees      FeeSlip[]
  dormBed   DormitoryBed?  @relation(fields: [dormBedId], references: [id])
  dormBedId String?
  optionalSubjects StudentOptionalSubject[]
  promotions Promotion[]
  finalResults FinalResult[]
  transport StudentTransport?

  @@unique([schoolId, studentId])
  @@map("students")
}

model Teacher {
  id             String   @id @default(cuid())
  schoolId       String
  userId         String   @unique
  employeeId     String?
  teacherId      String?
  qualification  String?
  designation    String?
  department     String?
  experience     Int?
  specialization String?
  dateOfBirth    DateTime?
  gender         Gender?
  address        String?
  photo          String?
  joiningDate    DateTime @default(now())
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  school          School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  attendance      TeacherAttendance[]
  payslips        StaffPayslip[]
  classesManaged  Class[]    @relation("ClassTeacher")
  substituting    ClassSubstitute[] @relation("SubstituteTeacher")

  @@map("teachers")
}

model Parent {
  id          String   @id @default(cuid())
  schoolId    String
  userId      String   @unique
  occupation  String?
  address     String?
  phone       String?
  photo       String?
  relation    String?
  createdAt   DateTime @default(now())

  school   School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  students StudentParent[]

  @@map("parents")
}

model StudentParent {
  studentId  String
  parentId   String
  relation   String? // Father, Mother, Guardian

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  parent  Parent  @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@id([studentId, parentId])
  @@map("student_parents")
}

model Employee {
  id          String   @id @default(cuid())
  schoolId    String
  userId      String   @unique
  employeeId  String?
  role        String?
  department  String?
  dateOfBirth DateTime?
  gender      Gender?
  address     String?
  photo       String?
  joiningDate DateTime @default(now())
  isActive    Boolean  @default(true)

  school     School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  salary     SalaryConfig?
  salarySlips SalarySlip[]

  @@map("employees")
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

model StudentOptionalSubject {
  studentId String
  subjectId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@id([studentId, subjectId])
  @@map("student_optional_subjects")
}

// ─────────────────────────────────────────────
// ATTENDANCE
// ─────────────────────────────────────────────

model DailyAttendance {
  id        String   @id @default(cuid())
  schoolId  String
  studentId String
  classId   String
  date      DateTime @db.Date
  status    AttendanceStatus @default(PRESENT)
  note      String?

  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([studentId, date])
  @@map("daily_attendance")
}

model TeacherAttendance {
  id        String   @id @default(cuid())
  teacherId String
  date      DateTime @db.Date
  status    AttendanceStatus @default(PRESENT)
  note      String?

  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, date])
  @@map("teacher_attendance")
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

// ─────────────────────────────────────────────
// EXAMINATIONS
// ─────────────────────────────────────────────

model Exam {
  id           String    @id @default(cuid())
  schoolId     String
  title        String
  description  String?
  term         String?
  academicYear String?
  startDate    DateTime?
  endDate      DateTime?
  isFinal      Boolean   @default(false)
  isPublished  Boolean   @default(false)
  createdAt    DateTime  @default(now())

  school     School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  routines   ExamRoutine[]
  attendance ExamAttendance[]
  grades     ExamGrade[]
  results    FinalResult[]

  @@map("exams")
}

model ExamRoutine {
  id        String   @id @default(cuid())
  examId    String
  classId   String
  subjectId String
  date      DateTime
  startTime String
  endTime   String
  room      String?

  exam    Exam    @relation(fields: [examId], references: [id], onDelete: Cascade)
  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@map("exam_routines")
}

model ExamAttendance {
  id        String   @id @default(cuid())
  examId    String
  studentId String
  status    AttendanceStatus @default(PRESENT)

  exam    Exam    @relation(fields: [examId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([examId, studentId])
  @@map("exam_attendance")
}

model ExamGrade {
  id          String  @id @default(cuid())
  examId      String
  grade       String
  minMark     Float
  maxMark     Float
  pointValue  Float?
  remark      String?

  exam Exam @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@map("exam_grades")
}

model SubjectMark {
  id        String  @id @default(cuid())
  studentId String
  subjectId String
  examId    String
  marks     Float
  grade     String?
  remark    String?

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([studentId, subjectId, examId])
  @@map("subject_marks")
}

model FinalResult {
  id          String       @id @default(cuid())
  studentId   String
  examId      String
  totalMarks  Float
  percentage  Float
  grade       String?
  rank        Int?
  status      ResultStatus @default(PENDING)
  approvedBy  String?
  approvedAt  DateTime?

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  exam    Exam    @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@unique([studentId, examId])
  @@map("final_results")
}

enum ResultStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
  PUBLISHED
}

model Promotion {
  id          String   @id @default(cuid())
  studentId   String
  fromClassId String
  toClassId   String
  promotedAt  DateTime @default(now())
  note        String?

  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  fromClass Class   @relation(fields: [fromClassId], references: [id])

  @@map("promotions")
}

// ─────────────────────────────────────────────
// FINANCE
// ─────────────────────────────────────────────

model AccountTitle {
  id          String          @id @default(cuid())
  schoolId    String
  title       String
  type        AccountType
  description String?

  school       School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@map("account_titles")
}

enum AccountType {
  INCOME
  EXPENSE
}

model Transaction {
  id          String      @id @default(cuid())
  schoolId    String
  titleId     String?
  amount      Float
  type        AccountType @default(INCOME)
  description String?
  reference   String?
  method      String?
  note        String?
  status      String      @default("COMPLETED")
  studentId   String?
  feeItemId   String?
  date        DateTime    @default(now())

  school School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  title  AccountTitle? @relation(fields: [titleId], references: [id])

  @@map("transactions")
}

model FeeItem {
  id           String  @id @default(cuid())
  schoolId     String
  classId      String?
  title        String
  amount       Float
  term         String?
  academicYear String?
  isAnnual     Boolean @default(false)

  school School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  class  Class?  @relation(fields: [classId], references: [id])
  slips  FeeSlip[]

  @@map("fee_items")
}

model FeeSlip {
  id          String    @id @default(cuid())
  studentId   String
  feeItemId   String
  amount      Float
  paidAmount  Float     @default(0)
  dueDate     DateTime?
  paidAt      DateTime?
  paystackRef String?
  status      FeeStatus @default(UNPAID)

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  feeItem FeeItem @relation(fields: [feeItemId], references: [id])

  @@map("fee_slips")
}

enum FeeStatus {
  UNPAID
  PARTIAL
  PAID
}

model SalaryConfig {
  id         String  @id @default(cuid())
  employeeId String  @unique
  amount     Float
  frequency  String  @default("MONTHLY")

  employee   Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  school     School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  schoolId   String
  slips      SalarySlip[]

  @@map("salary_configs")
}

model SalarySlip {
  id           String    @id @default(cuid())
  salaryId     String
  employeeId   String
  amount       Float
  month        Int
  year         Int
  paidAt       DateTime?
  paystackRef  String?
  status       FeeStatus @default(UNPAID)

  salary   SalaryConfig @relation(fields: [salaryId], references: [id], onDelete: Cascade)
  employee Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("salary_slips")
}

// Staff Payslip - linked directly to Teacher, with customizable allowances/deductions
model StaffPayslip {
  id          String    @id @default(cuid())
  schoolId    String
  teacherId   String
  month       Int       // 1-12
  year        Int
  basicSalary Float
  allowances  Json      @default("[]") // [{name: "Housing", amount: 500}]
  deductions  Json      @default("[]") // [{name: "SSNIT", amount: 100}]
  netPay      Float
  notes       String?
  status      String    @default("DRAFT") // DRAFT | ISSUED | PAID
  issuedAt    DateTime?
  createdAt   DateTime  @default(now())

  school   School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacher  Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, month, year])
  @@map("staff_payslips")
}

// ─────────────────────────────────────────────
// LIBRARY
// ─────────────────────────────────────────────

model Book {
  id           String   @id @default(cuid())
  schoolId     String
  title        String
  author       String?
  isbn         String?
  categoryId   String?
  categoryName String?
  quantity     Int      @default(1)
  available    Int      @default(1)
  shelfNo      String?
  cover        String?
  publishYear  Int?
  createdAt    DateTime @default(now())

  school   School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  category BookCategory? @relation(fields: [categoryId], references: [id])
  issues   BookIssue[]

  @@map("books")
}

model BookCategory {
  id          String  @id @default(cuid())
  name        String
  parentId    String?
  description String?

  parent   BookCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children BookCategory[] @relation("CategoryTree")
  books    Book[]

  @@map("book_categories")
}

model LibraryMember {
  id       String  @id @default(cuid())
  userId   String  @unique
  memberId String?

  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  issues BookIssue[]

  @@map("library_members")
}

model BookIssue {
  id         String    @id @default(cuid())
  bookId     String
  memberId   String
  issueDate  DateTime  @default(now())
  dueDate    DateTime
  returnDate DateTime?
  fine       Float?
  status     IssueStatus @default(ISSUED)

  book   Book          @relation(fields: [bookId], references: [id], onDelete: Cascade)
  member LibraryMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@map("book_issues")
}

enum IssueStatus {
  ISSUED
  RETURNED
  OVERDUE
}

// ─────────────────────────────────────────────
// DORMITORY
// ─────────────────────────────────────────────

model Dormitory {
  id       String        @id @default(cuid())
  schoolId String
  name     String
  type     DormitoryType
  capacity Int
  warden   String?

  school School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  rooms  DormitoryRoom[]

  @@map("dormitories")
}

enum DormitoryType {
  BOYS
  GIRLS
  STAFF
}

model DormitoryRoom {
  id          String  @id @default(cuid())
  dormitoryId String
  roomNumber  String
  bedCount    Int

  dormitory Dormitory     @relation(fields: [dormitoryId], references: [id], onDelete: Cascade)
  beds      DormitoryBed[]

  @@map("dormitory_rooms")
}

model DormitoryBed {
  id     String  @id @default(cuid())
  roomId String
  bedNumber String
  isOccupied Boolean @default(false)

  room     DormitoryRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  students Student[]

  @@map("dormitory_beds")
}

// ─────────────────────────────────────────────
// TRANSPORT
// ─────────────────────────────────────────────

model Transport {
  id           String  @id @default(cuid())
  schoolId     String
  route        String?
  routeName    String?
  vehicle      String?
  vehicleNo    String?
  vehicleModel String?
  driverName   String?
  driverPhone  String?
  capacity     Int?
  fare         Float?

  school   School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  students StudentTransport[]

  @@map("transports")
}

model StudentTransport {
  id          String   @id @default(cuid())
  studentId   String
  transportId String
  pickupPoint String?
  assignedAt  DateTime @default(now())

  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  transport Transport @relation(fields: [transportId], references: [id], onDelete: Cascade)

  @@unique([studentId])
  @@map("student_transports")
}

// ─────────────────────────────────────────────
// INVENTORY
// ─────────────────────────────────────────────

model Vendor {
  id      String  @id @default(cuid())
  name    String
  phone   String?
  email   String?
  address String?

  items InventoryItem[]

  @@map("vendors")
}

model InventoryCategory {
  id          String  @id @default(cuid())
  name        String
  description String?

  items InventoryItem[]

  @@map("inventory_categories")
}

model InventoryItem {
  id         String  @id @default(cuid())
  schoolId   String
  categoryId String?
  vendorId   String?
  name       String
  quantity   Int     @default(0)
  rate       Float   @default(0)
  unitPrice  Float?
  unit       String?
  supplier   String?
  discount   Float?

  school   School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  category InventoryCategory? @relation(fields: [categoryId], references: [id])
  vendor   Vendor?            @relation(fields: [vendorId], references: [id])
  issues   ItemIssue[]

  @@map("inventory_items")
}

model ItemIssue {
  id          String    @id @default(cuid())
  itemId      String
  recipientId String
  recipientType String  // STUDENT | EMPLOYEE
  quantity    Int
  issueDate   DateTime  @default(now())
  status      FeeStatus @default(UNPAID)

  item InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("item_issues")
}

// ─────────────────────────────────────────────
// COMMUNICATION
// ─────────────────────────────────────────────

model Notice {
  id        String    @id @default(cuid())
  schoolId  String
  title     String
  content   String
  audience  String?
  priority  String    @default("NORMAL")
  expiresAt DateTime?
  postedBy  String    @default("Admin")
  createdAt DateTime  @default(now())

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@map("notices")
}

model Message {
  id        String   @id @default(cuid())
  schoolId  String
  senderId  String
  subject   String?
  body      String
  createdAt DateTime @default(now())

  school     School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  sender     User               @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  recipients MessageRecipient[]

  @@map("messages")
}

model MessageRecipient {
  messageId  String
  userId     String
  isRead     Boolean  @default(false)
  readAt     DateTime?

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([messageId, userId])
  @@map("message_recipients")
}

// ─────────────────────────────────────────────
// CHAT (real-time threaded conversations)
// ─────────────────────────────────────────────
model Conversation {
  id          String   @id @default(cuid())
  schoolId    String
  isGroup     Boolean  @default(false)
  name        String?  // null for 1:1, set for group chats
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  school      School                    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdBy   User                      @relation("CreatedConversations", fields: [createdById], references: [id], onDelete: Cascade)
  participants ConversationParticipant[]
  messages    ChatMessage[]

  @@index([schoolId])
  @@map("conversations")
}

model ConversationParticipant {
  id             String    @id @default(cuid())
  conversationId String
  userId         String
  joinedAt       DateTime  @default(now())
  lastReadAt     DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("conversation_participants")
}

model ChatMessage {
  id             String    @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  createdAt      DateTime  @default(now())
  deletedAt      DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("SentChatMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("chat_messages")
}

model Suggestion {
  id        String   @id @default(cuid())
  schoolId  String
  userId    String?
  subject   String
  body      String
  isAnon    Boolean  @default(false)
  status    String   @default("PENDING")
  createdAt DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("suggestions")
}

// ─────────────────────────────────────────────
// LEAVE MANAGEMENT
// ─────────────────────────────────────────────

model LeaveApplication {
  id        String      @id @default(cuid())
  schoolId  String
  userId    String
  leaveType String      @default("CASUAL")
  startDate DateTime
  endDate   DateTime
  reason    String
  status    LeaveStatus @default(PENDING)
  checkedBy String?
  checkedAt DateTime?
  createdAt DateTime    @default(now())

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("leave_applications")
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  ENDED
}

// ─────────────────────────────────────────────
// CONFIGURATION
// ─────────────────────────────────────────────

model Configuration {
  id           String  @id @default(cuid())
  schoolId     String  @unique
  smsApiKey    String?
  smsApiUrl    String?
  emailApiKey  String?
  smsSender    String?

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@map("configurations")
}

model WeekDay {
  id       String    @id @default(cuid())
  schoolId String
  day      DayOfWeek
  isOpen   Boolean   @default(true)

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, day])
  @@map("week_days")
}

model CalendarEvent {
  id          String    @id @default(cuid())
  schoolId    String
  userId      String?
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime?
  type        String?
  color       String?
  allDay      Boolean   @default(false)

  school School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("calendar_events")
}

// ─────────────────────────────────────────────
// PERMISSIONS / DELEGATION
// ─────────────────────────────────────────────

// Grants a specific user a named permission (e.g. ADMIT_STUDENTS)
model UserPermission {
  id         String   @id @default(cuid())
  schoolId   String
  userId     String
  permission String   // e.g. "ADMIT_STUDENTS"
  grantedBy  String   // userId of admin who granted it
  createdAt  DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user   User   @relation("GrantedPermissions", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([schoolId, userId, permission])
  @@map("user_permissions")
}

// ─────────────────────────────────────────────
// PLATFORM / SUPER ADMIN
// ─────────────────────────────────────────────

// Global platform configuration (singleton — only one row)
model PlatformConfig {
  id                    String  @id @default(cuid())
  paystackSecretKey     String? // Platform Paystack secret key
  paystackPublicKey     String? // Platform Paystack public key
  paystackWebhookSecret String?
  feePerStudentTermly   Float   @default(15)   // Legacy: GH₵15 per student per term (kept for reference)
  platformFeePercent    Float   @default(0)    // % deducted from each payment (0 = school keeps 100%)
  currency              String  @default("GHS")
  siteName              String  @default("NexSchoola")
  supportEmail          String?
  // Yearly flat plan prices (set by super admin)
  planPriceBasic        Float   @default(500)   // GH₵500/year
  planPricePro          Float   @default(1200)  // GH₵1200/year
  planPriceEnterprise   Float   @default(2500)  // GH₵2500/year
  updatedAt             DateTime @updatedAt

  @@map("platform_configs")
}
